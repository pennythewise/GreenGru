# Example environment variables for connecting to a Supabase/Postgres database
# Copy this file to `.env` and replace the placeholders with your project values.

# SQLAlchemy / AsyncPG connection string. Use the `+asyncpg` scheme the
# app expects, for example:
# DATABASE_URL=postgresql+asyncpg://postgres:password@db.project_ref.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>

# Optional Supabase project details (only required for Storage/Auth features)
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SERVICE_ROLE_KEY>

# Keep LLM mock mode `true` for now unless you have a real API key configured
LLM_MOCK_MODE=true

# CBAM certificate price (update quarterly)
CBAM_CERTIFICATE_PRICE_EUR=75.36
CBAM_CERTIFICATE_PRICE_QUARTER=Q1-2026
