# =============================================================================
# GreenGru backend — copy to .env and fill in the values you need.
#   cp .env.example .env          (macOS/Linux)
#   copy .env.example .env        (Windows)
# =============================================================================
#
# MVP LLM stack = OpenRouter (OpenAI-compatible). You can use ONE shared key
# in LLM_API_KEY, or a separate key per role below (recommended if you have
# per-model credits / rate limits).
#
# Without any key the app still runs in mock mode (deterministic demo output).


# -----------------------------------------------------------------------------
# REQUIRED for real cloud behaviour (not mock mode)
# -----------------------------------------------------------------------------

# Shared OpenAI-compatible endpoint (all roles use this unless you fork later)
# MVP: https://openrouter.ai/api/v1
LLM_BASE_URL=https://openrouter.ai/api/v1

# Shared fallback key — used whenever a role-specific key below is empty
LLM_API_KEY=

# --- Per-role OpenRouter keys (optional; fall back to LLM_API_KEY) ---------
# Copilot sidebar + /entry chat → MODEL_COPILOT
LLM_COPILOT_API_KEY=
# CN-code classifier → MODEL_CLASSIFIER (Flash). Escalation uses Plus key chain.
LLM_CLASSIFIER_API_KEY=
# New Submission OCR fallback + Stage-1 PDF VL → MODEL_INTAKE_VISION / MODEL_PDF_VISION
LLM_VISION_API_KEY=
# Qwen3-Embedding-8B → MODEL_EMBEDDING (RAG + intake PDF vectors)
LLM_EMBEDDING_API_KEY=
# Passport / financing writing agents → MODEL_WRITING
LLM_WRITING_API_KEY=

# --- Models (OpenRouter slugs) ---------------------------------------------
MODEL_COPILOT=qwen/qwen3.7-plus
MODEL_CLASSIFIER=qwen/qwen3.6-flash
# Low-confidence CN classify retry (PRD §8.3) — uses LLM_WRITING / COPILOT / CLASSIFIER / API key
MODEL_CLASSIFIER_ESCALATION=qwen/qwen3.7-plus
MODEL_WRITING=qwen/qwen3.7-plus
# New Submission: PaddleOCR → this VL model
MODEL_INTAKE_VISION=qwen/qwen3-vl-235b-a22b-thinking
# Stage-1 CBAM/loan/grant PDF: MinerU → this VL → pymupdf/pypdf
MODEL_PDF_VISION=qwen/qwen3-vl-235b-a22b-thinking
MODEL_EMBEDDING=qwen/qwen3-embedding-8b
EMBEDDING_DIMENSIONS=1024

# PDF_VL_MAX_PAGES=20
# PDF_VL_DPI=144
# PDF_VL_TIMEOUT_S=180

# Turn off mock completions once at least one key is set.
LLM_MOCK_MODE=false

# Supabase project URL + service-role key.
# Used for: intake document_embeddings + RAG kb_chunks / upload_chunks (pgvector).
# Get from: Supabase dashboard → Project Settings → API
# Run migrations first:
#   supabase/migrations/0002_document_embeddings.sql  (intake PDF vectors)
#   supabase/migrations/0003_kb_chunks.sql            (RAG kb_chunks + match_kb_chunks)
#   supabase/migrations/0004_upload_chunks.sql        (user upload RAG cache)
# Ingest EU CBAM guidance:  python -m scripts.ingest_kb_cbam
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# RECOMMENDED when using Supabase as your main database (not local SQLite)
# -----------------------------------------------------------------------------
# If unset, backend uses ./carbon_passport.db (SQLite) — fine for OCR preview
# and local testing. Set this when you want submissions/pipeline data in Supabase.
#
# DATABASE_URL=postgresql+asyncpg://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Also run: supabase/migrations/0001_init.sql (core schema)


# -----------------------------------------------------------------------------
# OPTIONAL — local dev defaults are fine
# -----------------------------------------------------------------------------

# --- PaddleOCR (in-process Stage-1 image OCR) -----------------------------
# lang=ch → simplified Chinese + English only (PP-OCR Chinese model).
# Models auto-download on first request. See backend/PADDLEOCR.md.
# PADDLEOCR_ENABLED=true
# PADDLEOCR_LANG=ch
# PADDLEOCR_VERSION=PP-OCRv4
# PADDLEOCR_ENABLE_MKLDNN=false
# PADDLEOCR_TIMEOUT_S=45
# OCR_INTAKE_TIMEOUT_S=90   # Qwen-VL fallback (235B needs headroom)
# Temp: skip PaddleOCR + qwen vision on upload — mock templates only.
# OCR_MOCK_ONLY=false

# Frontend dev server origin(s) for CORS (comma-separated).
# FRONTEND_ORIGIN=http://localhost:3000,http://localhost:8080

# Local folder for generated PDFs + embedding JSON fallback when Supabase is down.
# LOCAL_STORAGE_DIR=./storage

# CBAM certificate price — refresh each quarter (PRD §6.2).
# CBAM_CERTIFICATE_PRICE_EUR=75.36
# CBAM_CERTIFICATE_PRICE_QUARTER=Q1-2026

# CN-code classifier escalation threshold (PRD §8.3).
# CLASSIFIER_CONFIDENCE_THRESHOLD=0.7

# HMAC secret for signed PDF output — change before any real deployment.
# DOCUMENT_SIGNING_SECRET=dev-only-insecure-secret-change-me

# Baowu/Ansteel integration API key (query param ?api_key=). Demo default: greengru-demo-key
# INTEGRATION_API_KEY=greengru-demo-key

# Stage-0 ModelScope pre-screen (StructBERT + DAMO OCR) — off by default.
# ENABLE_MODELSCOPE_PRESCREEN=false

# Optional local MinerU (PDF → Markdown). Stage-1 prefers MinerU, then Qwen-VL.
# Install (backend venv, stop uvicorn first):
#   python -m pip install -U "mineru[core]"
#   python -m pip install "numpy>=1.24,<2.4"   # keep PaddleOCR happy
#   # Windows symlink fix (required unless Developer Mode is on):
#   set HF_HUB_DISABLE_SYMLINKS=1
#   python -m mineru.cli.models_download -s huggingface -m pipeline
# Do NOT set MINERU_MODEL_SOURCE=modelscope for this MVP.
# Without MinerU: Qwen-VL → pymupdf → pypdf.
HF_HUB_DISABLE_SYMLINKS=1
# MINERU_MODEL_SOURCE=huggingface
