# Database — defaults to a local SQLite file if unset, so the whole
# pipeline runs with zero setup. Point this at a Supabase Postgres
# connection string (postgresql+asyncpg://...) for a real deployment; the
# schema (supabase/migrations/0001_init.sql) is identical either way.
DATABASE_URL=sqlite+aiosqlite:///./carbon_passport.db

# Supabase (Storage/Auth) — optional for local dev.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# DashScope — Qwen models via Alibaba Cloud Model Studio
# IMPORTANT: Beijing region endpoint — load-bearing for data sovereignty
# (PRD §10), NOT a default to leave unset. This is the legacy fixed Beijing
# domain (simplest correct choice for an MVP, no workspace ID needed).
# NEVER point this at dashscope-intl.aliyuncs.com (Singapore/international)
# or the ap-southeast-1 workspace domain — verified via Alibaba Cloud's own
# docs (help.aliyun.com/en/model-studio/qwen-api-via-openai-chat-completions).
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ^ Once you provision a Model Studio workspace, prefer the newer
# workspace-scoped domain for better performance/stability:
# https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1

# If unset or DASHSCOPE_API_KEY is empty, every agent call returns a
# deterministic mock response instead of a real completion — this is what
# lets the full pipeline (including PDF generation) run end-to-end with no
# external dependency. Set to false once a real API key is configured.
LLM_MOCK_MODE=true

# Stage-0 ModelScope pre-screen (PRD §4.2, §8.0) — optional, feature-flagged,
# off by default (requires the `modelscope` package + first-run model
# downloads). The pipeline runs correctly with this left false.
ENABLE_MODELSCOPE_PRESCREEN=false

# CBAM certificate price — refresh each quarter (PRD §6.2). Prefer adding a
# new row to app/data/cert_price.py over editing this default.
CBAM_CERTIFICATE_PRICE_EUR=75.36
CBAM_CERTIFICATE_PRICE_QUARTER=Q1-2026

CLASSIFIER_CONFIDENCE_THRESHOLD=0.7

LOCAL_STORAGE_DIR=./storage
FRONTEND_ORIGIN=http://localhost:3000

# HMAC secret for document hash+signature (PRD §9.3). Change this in any
# real deployment — the default is intentionally insecure.
DOCUMENT_SIGNING_SECRET=dev-only-insecure-secret-change-me
