# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# DashScope — Qwen models via Alibaba Cloud Model Studio
# IMPORTANT: Beijing region endpoint — load-bearing for data sovereignty (PRD §10).
# dashscope.aliyuncs.com = Beijing (mainland China data residency).
# dashscope-intl.aliyuncs.com = Singapore/international — NEVER use it here.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# CBAM certificate price — refresh each quarter (PRD §6.2)
CBAM_CERTIFICATE_PRICE_EUR=75.36
CBAM_CERTIFICATE_PRICE_QUARTER=Q1-2026
