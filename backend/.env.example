# =============================================================================
# GreenGru backend — copy to .env and fill in the values you need.
#   cp .env.example .env          (macOS/Linux)
#   copy .env.example .env        (Windows)
# =============================================================================
#
# For your current build (New Submission OCR + PDF embeddings), you mainly need:
#   1. Qwen / DashScope  — real invoice parsing, CN classify, text-embedding-v4
#   2. Supabase          — PDF vector storage (pgvector) + optional Postgres DB
#
# Everything else has sane defaults and can stay commented out for local dev.
# Without Qwen keys the app still runs in mock mode (deterministic demo output).


# -----------------------------------------------------------------------------
# REQUIRED for real cloud behaviour (not mock mode)
# -----------------------------------------------------------------------------

# Alibaba Cloud Model Studio / QwenCloud — pick the base URL that matches your key.
#
# QwenCloud Pay-As-You-Go keys (sk-ws-... from qwen.cloud dashboard):
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#
# Mainland Model Studio keys (Beijing data residency — PRD production default):
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#
DASHSCOPE_API_KEY=

# Copilot chat (sidebar + /entry) — separate key optional; falls back to DASHSCOPE_API_KEY.
DASHSCOPE_COPILOT_API_KEY=
MODEL_COPILOT=qwen/qwen3.7-plus

# All LLM agents use qwen3.7-plus — embedding is the only separate model.
MODEL_CLASSIFIER=qwen/qwen3.7-plus
MODEL_CLASSIFIER_ESCALATION=qwen/qwen3.7-plus
MODEL_INTAKE_VISION=qwen/qwen3.7-plus
MODEL_WRITING=qwen/qwen3.7-plus

# Turn off mock completions once DASHSCOPE_API_KEY is set.
LLM_MOCK_MODE=false

# PDF text embeddings only — not qwen3.7-plus
MODEL_EMBEDDING=text-embedding-v4

# Supabase project URL + service-role key.
# Used for: PDF text-embedding-v4 vectors → document_embeddings table (pgvector).
# Get from: Supabase dashboard → Project Settings → API
# Run migration first: supabase/migrations/0002_document_embeddings.sql
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# RECOMMENDED when using Supabase as your main database (not local SQLite)
# -----------------------------------------------------------------------------
# If unset, backend uses ./carbon_passport.db (SQLite) — fine for OCR preview
# and local testing. Set this when you want submissions/pipeline data in Supabase.
#
# DATABASE_URL=postgresql+asyncpg://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Also run: supabase/migrations/0001_init.sql (core schema)


# -----------------------------------------------------------------------------
# OPTIONAL — local dev defaults are fine
# -----------------------------------------------------------------------------

# DashScope OpenAI-compatible endpoint (Beijing). Change only if you have a
# Model Studio workspace-scoped URL provisioned.
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# chineseocr sidecar for photo/scanned invoice OCR (https://github.com/chineseocr/chineseocr).
# IMPORTANT: use port 8081+ — port 8080 is the GreenGru Vite dev server, not OCR.
#   cd chineseocr && pip install -r requirements.txt  # first time only
#   python app.py 8081
# CHINESE_OCR_URL=http://localhost:8081/ocr
# OCR_INTAKE_TIMEOUT_S=5

# Frontend dev server origin(s) for CORS (comma-separated).
# FRONTEND_ORIGIN=http://localhost:3000,http://localhost:8080

# Local folder for generated PDFs + embedding JSON fallback when Supabase is down.
# LOCAL_STORAGE_DIR=./storage

# CBAM certificate price — refresh each quarter (PRD §6.2).
# CBAM_CERTIFICATE_PRICE_EUR=75.36
# CBAM_CERTIFICATE_PRICE_QUARTER=Q1-2026

# CN-code classifier escalation threshold (PRD §8.3).
# CLASSIFIER_CONFIDENCE_THRESHOLD=0.7

# HMAC secret for signed PDF output — change before any real deployment.
# DOCUMENT_SIGNING_SECRET=dev-only-insecure-secret-change-me

# Baowu/Ansteel integration API key (query param ?api_key=). Demo default: greengru-demo-key
# INTEGRATION_API_KEY=greengru-demo-key

# Stage-0 ModelScope pre-screen (StructBERT + DAMO OCR) — off by default.
# ENABLE_MODELSCOPE_PRESCREEN=false
